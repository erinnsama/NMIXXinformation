{
  "version": 2,
  "builds": [
    { "src": "api/*.py",  "use": "@vercel/python" },
    { "src": "*.html",    "use": "@vercel/static" },
    { "src": "*.js",      "use": "@vercel/static" },
    { "src": "*.css",     "use": "@vercel/static" },
    { "src": "data/**",   "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/submit",  "dest": "/api/submit.py"  },
    { "src": "/api/approve", "dest": "/api/approve.py" },
    { "src": "/api/delete",  "dest": "/api/delete.py"  },
    { "src": "/api/trigger", "dest": "/api/trigger.py" },
    { "src": "/api/edit",    "dest": "/api/edit.py"    },
    { "src": "/api/pending", "dest": "/api/pending.py" },
    { "src": "/api/posts",   "dest": "/api/posts.py"   },
    { "src": "/(.*)",        "dest": "/$1"             }
  ]
}
