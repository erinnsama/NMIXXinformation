# Threads 帳號（存在 GitHub Secrets，不要 commit .env）
THREADS_USERNAME=
THREADS_PASSWORD=

# GitHub 個人存取權杖（供更新按鈕觸發 GitHub Actions）
# 建立方式：GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# 需要權限：Actions (Read and Write)
GITHUB_PAT=

# 你的 GitHub 帳號名稱與 repo 名稱
GITHUB_OWNER=
GITHUB_REPO=nmixx-fansite
